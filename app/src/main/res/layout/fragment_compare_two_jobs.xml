<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.comparison.CompareTwoJobsFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/cmp_tbl_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <HorizontalScrollView
                android:id="@+id/cmp_tbl_layout_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TableLayout
                    android:id="@+id/cmp_tbl_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:stretchColumns="1,2"
                    android:shrinkColumns="1,2">

                    <!-- Header -->
                    <TableRow>
                        <TextView
                            style="@style/CompareTableCellHeader"
                            android:text="Fields"/>
                        <TextView
                            style="@style/CompareTableCellHeader"
                            android:id="@+id/cmp_tbl_header_left"
                            android:text="Job 1"/>
                        <TextView
                            style="@style/CompareTableCellHeader"
                            android:id="@+id/cmp_tbl_header_right"
                            android:text="Job 2"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Title -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Title"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_title_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_title_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Company -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Company"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_company_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_company_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Location -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Location"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_location_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_location_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Adjusted Salary -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Adjusted Yearly\nSalary"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_ays_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_ays_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Adjusted Bonus -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Adjusted Yearly\nBonus"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_ayb_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_ayb_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- 401K -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="401K Match (%)"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_401k_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_401k_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Internet Stipend -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Internet Stipend"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_is_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_is_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Accident Insurance -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Accident Insurance"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_ai_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_ai_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Tuition Reimbursement -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Tuition\nReimbursement"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_tr_left"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_tr_right"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                    <!-- Job Score -->
                    <TableRow>
                        <TextView style="@style/CompareTableCellField" android:text="Job Score"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_js_left"
                            android:textStyle="bold"/>
                        <TextView style="@style/CompareTableCell" android:id="@+id/cmp_tbl_js_right"
                            android:textStyle="bold"/>
                    </TableRow>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"/>

                </TableLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/cmp_table_button_layout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/cmp_tbl_layout_scroll"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/cmp_tbl_main_menu_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Go Back to Main Menu"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/cmp_tbl_new_compare_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="New Comparison"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>